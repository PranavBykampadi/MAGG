# Copy this file to `.env` and fill in your credentials.
# See README for the full list of supported variables.

# --- LLM backend selection ---
# "openai" (default) routes calls to the OpenAI API.
# "ollama" routes calls to a local or remote Ollama server.
LLM_BACKEND=openai

# --- OpenAI backend (used when LLM_BACKEND=openai) ---
OPENAI_API_KEY=your_api_key_here

# --- Ollama backend (used when LLM_BACKEND=ollama) ---
# OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Optional: per-call usage logging (one JSONL line per LLM call) ---
# LLM_USAGE_LOG=./logs/llm_usage.jsonl
